rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTeacher() {
      return isAuthed() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /school/info {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isAuthed() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthed() && request.auth.uid == userId;
      allow update: if isAuthed() && (request.auth.uid == userId || isAdmin());
      allow list: if isAuthed(); 
      allow delete: if isAdmin();
    }

    match /classRoutines/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /notices/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /holidays/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
    
    match /exams/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /students/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
    
    match /staff/{id} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }
    
    match /results/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    match /messageLogs/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed();
      allow delete: if isAdmin();
    }

    match /emailLogs/{id} {
      allow read, write: if isAuthed();
    }

    match /feeCollections/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    match /transactions/{id} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }
  }
}